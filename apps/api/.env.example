DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h
ADMIN_REGISTRATION_SECRET=change-me-admin-secret

# AI proxy (production) — base URL must include /v1, e.g. https://your-proxy.com/v1
AI_BASE_URL=https://your-ai-proxy-base-url/v1
AI_API_KEY=your-ai-proxy-api-key
AI_MODEL=gpt-4o

# Local model via Ollama — set USE_LOCAL_MODEL=true to use instead of AI proxy
USE_LOCAL_MODEL=false
LOCAL_MODEL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL_NAME=llama3.2
# LOCAL_MODEL_API_KEY is optional for Ollama (defaults to "local")

POSTHOG_API_KEY=phc_your_server_side_key
