{
    "name": "@derbysoft/neat-design-token",
    "version": "2.4.0",
    "description": "",
    "keywords": [
        "design-token",
        "neat",
        "neat-design",
        "neat-design-token"
    ],
    "homepage": "https://bitbucket.org/derbysoft/neat-design-token#readme",
    "bugs": {
        "url": "https://bitbucket.org/derbysoft/neat-design-token/issues"
    },
    "license": "MIT",
    "main": "lib/index.js",
    "module": "es/index.js",
    "types": "es/index.d.ts",
    "files": [
        "lib",
        "es",
        "LICENSE",
        "README.md"
    ],
    "scripts": {
        "analyzer": "ANALYZE=1 npm run build",
        "build": "npm run clean && father build",
        "clean": "rimraf lib es dist",
        "dev": "npm run build && npm link",
        "do-publish": "npm publish --@derbysoft:registry=https://repo.dbaws.net/repository/derbysoft-npm/",
        "lint": "npm run lint:es",
        "lint:es": "eslint \"{src,test}/**/*.{js,jsx,ts,tsx}\"",
        "prepublishOnly": "npm run test && npm run build",
        "release:alpha": "npm version prerelease --preid=alpha",
        "rmlink": "npm uninstall -g @derbysoft/neat-design",
        "start": "npm run dev",
        "test": "jest",
        "test-pipe": "jest --no-watch --source-map=false --runInBand"
    },
    "commitlint": {
        "extends": [
            "@commitlint/config-conventional"
        ]
    },
    "lint-staged": {
        "*.{md,json}": [
            "prettier --write --no-error-on-unmatched-pattern"
        ],
        "*.{js,jsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{ts,tsx}": [
            "eslint --fix",
            "prettier --parser=typescript --write"
        ]
    },
    "devDependencies": {
        "@babel/preset-env": "^7.28.5",
        "@commitlint/cli": "^20.2.0",
        "@commitlint/config-conventional": "^20.2.0",
        "@jest/globals": "^30.2.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.0.3",
        "@typescript-eslint/eslint-plugin": "^8.50.1",
        "@typescript-eslint/parser": "^8.50.1",
        "babel-jest": "^30.2.0",
        "eslint": "^8.57.0",
        "eslint-plugin-jest": "^29.11.1",
        "eslint-plugin-prettier": "^5.5.4",
        "father": "4.5.0",
        "husky": "^9.1.7",
        "jest": "^30.2.0",
        "jest-environment-jsdom": "^30.2.0",
        "jest-extended": "^7.0.0",
        "lint-staged": "^16.2.7",
        "prettier": "^3.7.4",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-packagejson": "^2.5.20",
        "rimraf": "^6.1.2",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    },
    "publishConfig": {
        "access": "public"
    },
    "authors": [
        "liangxiaojun",
        "pipi"
    ]
}
